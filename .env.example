# =============================================================================
# Dubai Retail OS · Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to version control.
# =============================================================================

# PostgreSQL
POSTGRES_DB=dubai_retail
POSTGRES_USER=dubai_admin
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_PORT=5432
# IMPORTANT: The password is baked into the Postgres data volume on first boot only.
# If you change POSTGRES_PASSWORD later, Postgres still uses the OLD password until you
# run: ALTER USER ... PASSWORD, or remove the postgres_data volume (wipes DB) and compose up again.
# DATABASE_URL in docker-compose for `api` uses this same POSTGRES_PASSWORD — they must match.

# Redis
REDIS_PASSWORD=change_me_in_prod
REDIS_PORT=6379

# API
API_PORT=8080
# Publish the SvelteKit storefront on this host port (maps to container port 3000).
STOREFRONT_PORT=5173
JWT_SECRET=generate_a_strong_random_secret_here
RESERVATION_TTL_S=900

# Remote browser access (set when admin / storefront is opened by URL, not localhost)
# Comma-separated extra CORS origins for the API (browser Origin header).
# Include both admin and storefront when exposed, e.g. :3000 and :5173
CORS_ALLOWED_ORIGINS=http://YOUR_PUBLIC_IP:3000,http://YOUR_PUBLIC_IP:5173
# Base URL the *browser* uses to call the API (same host as API, port 8080).
NEXT_PUBLIC_API_BASE_URL=http://YOUR_PUBLIC_IP:8080

# SvelteKit storefront (client + SSR). Same idea as admin; inferred on public hosts if unset/loopback.
PUBLIC_API_BASE_URL=http://YOUR_PUBLIC_IP:8080
PUBLIC_API_PORT=8080

# Business
VAT_RATE=0.05
CURRENCY=AED

# UAE E-Invoice / PINT-AE (Seller identity)
SELLER_NAME=Dubai Fashion House LLC
SELLER_NAME_AR=دبي فاشن هاوس ذ.م.م
SELLER_TRN=100000000000003
SELLER_TRADE_LICENSE=1234567
SELLER_GLN=0000000000000
SELLER_STREET=Al Quoz Industrial Area 3
SELLER_CITY=Dubai
SELLER_POSTAL=
SELLER_EMAIL=accounts@yourstore.ae

# ASP Sandbox (UAE FTA Accredited Service Provider)
ASP_SANDBOX_ENDPOINT=https://sandbox.asp.example.ae/validate
ASP_API_KEY=your_asp_api_key_here

# Payment Gateways
PAYMENT_GATEWAY_DEFAULT=stripe
PAYMENT_GATEWAY_FALLBACK=network_international

# Slack Alerts
SLACK_WEBHOOK_OPERATIONS=https://hooks.slack.com/services/...
SLACK_WEBHOOK_CRITICAL=https://hooks.slack.com/services/...
SLACK_WEBHOOK_COMPLIANCE=https://hooks.slack.com/services/...
SLACK_WEBHOOK_ENGINEERING=https://hooks.slack.com/services/...

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=dubai_grafana
