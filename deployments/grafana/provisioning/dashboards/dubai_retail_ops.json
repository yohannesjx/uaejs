{
  "title": "Dubai Retail OS — Operational Dashboard",
  "uid": "dubai-retail-ops",
  "tags": ["dubai", "retail", "operations"],
  "timezone": "Asia/Dubai",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Orders Processed / Hour",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(dubai_retail_orders_processed_total[1h])) by (channel_type)",
          "legendFormat": "{{channel_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "Order Failures / Hour",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(dubai_retail_orders_failed_total[1h])) by (reason)",
          "legendFormat": "{{reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "fixedColor": "red", "mode": "fixed" } }
      }
    },
    {
      "id": 3,
      "title": "Active Stock Reservations",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        { "expr": "dubai_retail_active_reservations", "legendFormat": "Reservations" }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 200 }
          ]
        }
      }
    },
    {
      "id": 4,
      "title": "Pending Invoices (Compliance Gap)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        { "expr": "dubai_retail_pending_invoices", "legendFormat": "Pending" }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "orange", "value": 1 },
            { "color": "red", "value": 10 }
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "Reservations Expired (Cleanup Job)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        { "expr": "increase(dubai_retail_reservations_expired_total[1h])", "legendFormat": "Expired/hr" }
      ]
    },
    {
      "id": 6,
      "title": "QC Photo Mismatches",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        { "expr": "increase(dubai_retail_qc_photo_mismatch_total[24h])", "legendFormat": "Mismatches/day" }
      ],
      "options": {
        "colorMode": "background",
        "thresholds": {
          "steps": [
            { "color": "green", "value": 0 },
            { "color": "red", "value": 1 }
          ]
        }
      }
    },
    {
      "id": 7,
      "title": "Order Processing Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(dubai_retail_order_processing_duration_seconds_bucket[5m])) by (le, channel_type))",
          "legendFormat": "p95 {{channel_type}}"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(dubai_retail_order_processing_duration_seconds_bucket[5m])) by (le, channel_type))",
          "legendFormat": "p50 {{channel_type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 8,
      "title": "Invoices Generated by Type",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum(increase(dubai_retail_invoices_generated_total[24h])) by (invoice_type)",
          "legendFormat": "{{invoice_type}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Promotion Hits by Channel",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 12 },
      "targets": [
        {
          "expr": "sum(increase(dubai_retail_promotion_hits_total[24h])) by (channel_type, customer_tier)",
          "legendFormat": "{{channel_type}} / {{customer_tier}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Stock Movements by Type (24h)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "sum(increase(dubai_retail_stock_movements_total[24h])) by (movement_type)",
          "legendFormat": "{{movement_type}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Invoice Serialization Latency (p95)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(dubai_retail_invoice_serialization_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 ms"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 12,
      "title": "Returns Created (24h)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 20 },
      "targets": [
        {
          "expr": "sum(increase(dubai_retail_returns_created_total[24h]))",
          "legendFormat": "Returns"
        }
      ]
    }
  ]
}
